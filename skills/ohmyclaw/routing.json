  "plans": {
    "lite": {
      "priceUsdMonth": 3,
      "allowedModels": ["glm-5-turbo", "glm-5"],
      "blockedModels": ["glm-5.1"],
      "quota": {
        "dailyTokens": 1500000,
        "sessionTokens": 300000,
        "taskTokens": 60000,
        "dailyRequests": 600
      },
      "concurrency": { "maxWorkers": 2, "maxTotalSessions": 3 },
      "fixLoopMaxIterations": 2,
      "pipelineModes": ["solo", "parallel"]
    },
    "pro": {
      "priceUsdMonth": 15,
      "allowedModels": ["glm-5-turbo", "glm-5", "glm-5.1"],
      "blockedModels": [],
      "quota": {
        "dailyTokens": 8000000,
        "sessionTokens": 1500000,
        "taskTokens": 200000,
        "dailyRequests": 3000
      },
      "concurrency": { "maxWorkers": 4, "maxTotalSessions": 6 },
