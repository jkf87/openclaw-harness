  "codexOverlay": {
    "enabledWhen": "codex_oauth_enabled == true",
    "comment": "GPT-5.4 의 reasoning_score=97, coding_score=97 로 GLM-5.1 대비 소폭 우위. extended thinking 슬롯에 우선 오버레이.",
    "overrides": {
      "coding_arch":     { "MEDIUM": "gpt-5.4", "HIGH": "gpt-5.4" },
      "coding_general":  { "HIGH":   "gpt-5.4" },
      "debugging":       { "HIGH":   "gpt-5.4" },
      "security":        { "MEDIUM": "gpt-5.4", "HIGH": "gpt-5.4" },
      "reasoning":       { "HIGH":   "gpt-5.4" },
      "data_analysis":   { "HIGH":   "gpt-5.4" }
    }
  },

  "openrouterFreeOverlay": {
    "enabledWhen": "openrouter_prefer_free == true",
    "comment": "OPENROUTER_PREFER_FREE=true 시 LOW/MEDIUM 복잡도 작업을 무료 모델로 우선 배정 (P78). HIGH 복잡도는 품질 보장을 위해 유료 모델(P79 이하)로 위임. 무료 모델 없는 카테고리/티어 조합은 P79 openrouterOverlay로 graceful fallback.",
    "freeModels": ["openrouter-llama-3.3-70b-free", "openrouter-mistral-7b-free", "openrouter-qwen-2.5-72b-free", "openrouter-gemma-3-27b-free"],
    "overrides": {
      "coding_general":   { "LOW": "openrouter-mistral-7b-free",      "MEDIUM": "openrouter-llama-3.3-70b-free" },
      "coding_arch":      { "LOW": "openrouter-qwen-2.5-72b-free",    "MEDIUM": "openrouter-llama-3.3-70b-free" },
      "korean_nlp":       { "LOW": "openrouter-qwen-2.5-72b-free",    "MEDIUM": "openrouter-qwen-2.5-72b-free"  },
      "reasoning":        { "LOW": "openrouter-llama-3.3-70b-free",   "MEDIUM": "openrouter-llama-3.3-70b-free" },
      "debugging":        { "LOW": "openrouter-mistral-7b-free",      "MEDIUM": "openrouter-llama-3.3-70b-free" },
      "content_creation": { "LOW": "openrouter-gemma-3-27b-free",     "MEDIUM": "openrouter-llama-3.3-70b-free" },
      "data_analysis":    { "LOW": "openrouter-qwen-2.5-72b-free",    "MEDIUM": "openrouter-llama-3.3-70b-free" },
      "security":         { "LOW": "openrouter-llama-3.3-70b-free",   "MEDIUM": "openrouter-llama-3.3-70b-free" }
    }
  },

  "openrouterOverlay": {
    "enabledWhen": "openrouter_enabled == true",
    "comment": "OpenRouter 경유 외부 모델 오버레이. codexOverlay(P80) 다음, matrix(P75) 이전 P79 우선순위. codex+openrouter 동시 활성 시 codex 가 우선. coding_general/debugging 미커버: GLM-5.1 대비 OpenRouter 모델의 우위가 불명확하여 기본 matrix 위임.",
    "overrides": {
      "reasoning":       { "HIGH":   "openrouter-deepseek-r1" },
      "coding_arch":     { "HIGH":   "openrouter-claude-opus-4" },
      "data_analysis":   { "HIGH":   "openrouter-gemini-2.5-pro" },
      "korean_nlp":      { "HIGH":   "openrouter-qwen3-235b",   "MEDIUM": "openrouter-qwen3-235b" },
      "security":        { "HIGH":   "openrouter-claude-opus-4" }
    }
  },

  "complexityTiers": {
    "LOW":    { "min": 0,  "max": 4  },
    "MEDIUM": { "min": 5,  "max": 9  },
    "HIGH":   { "min": 10, "max": 20 }
  },

  "reasoningDetection": {
    "enabled": true,
    "minScore": 2,
    "comment": "감지되면 P81/P82 에 따라 reasoning_score 최상위 모델로 격상. LOW 복잡도라도 격상.",
    "keywordsKo": [
      "증명", "알고리즘", "복잡도", "수학", "최적화", "정합성",
      "상태 머신", "동형", "불변조건", "race condition",
      "분산 합의", "정렬 증명", "lock-free", "Byzantine"
    ],
    "keywordsEn": [
      "prove", "proof", "invariant", "complexity", "big-?o",
      "algorithm", "optimization", "theorem", "derive",
      "tradeoff", "race condition", "distributed consensus",
      "lock-free", "byzantine"
    ],
    "categories": ["reasoning", "coding_arch", "data_analysis", "security"],
    "categoryBonus": 1,
    "keywordBonus": 2
  },

  "koreanDetection": {
    "enabled": true,
    "thresholds": { "low": 0.3, "medium": 0.5, "high": 0.7 },
    "codingOverride": true
  },

  "accounts": {
    "comment": "다중 계정 풀 — pool.sh 가 round-robin/cooldown 으로 선택. 원본 accounts.yaml 의 JSON 화.",
    "poolDefaults": {
      "strategy": "round_robin",
      "cooldownSeconds": 60,
      "maxCooldownSeconds": 600,
      "backoffMultiplier": 2,
      "healthCheckInterval": 300,
      "fanOutTimeout": 30,
      "stateFile": "${OHMYCLAW_STATE_DIR:-~/.cache/ohmyclaw}/pool-state.json"
    },
    "pools": {
      "zai": {
        "providerId": "zai",
        "baseUrl": "https://api.z.ai/v1",
        "anthropicBaseUrl": "https://api.z.ai/api/anthropic",
        "strategy": "round_robin",
        "planAware": true,
        "modelPrefixes": ["glm-"],
        "accounts": [
          { "id": "zai-primary",   "authType": "oauth_zai", "openclawProfile": "default", "plan": "pro",  "weight": 10, "enabled": true  },
          { "id": "zai-secondary", "authType": "api_key",   "envKey": "ZAI_API_KEY_2",     "plan": "lite", "weight": 5,  "enabled": false },
          { "id": "zai-team-max",  "authType": "oauth_zai", "openclawProfile": "team",     "plan": "max",  "weight": 15, "enabled": false }
        ]
      },
      "codex": {
        "providerId": "openai-codex",
        "baseUrl": "https://api.openai.com/v1",
        "strategy": "round_robin",
        "optional": true,
        "modelPrefixes": ["gpt-"],
        "comment": "활성화: 1) codex login 2) 본 풀 enabled=true 3) CODEX_OAUTH_ENABLED=true",
        "accounts": [
          { "id": "codex-primary",   "authType": "oauth_codex", "codexHome": "~/.codex",       "weight": 10, "enabled": false },
          { "id": "codex-secondary", "authType": "oauth_codex", "codexHome": "~/.codex-acct2", "weight": 10, "enabled": false }
        ]
      },
      "openrouter": {
        "providerId": "openrouter",
        "baseUrl": "https://openrouter.ai/api/v1",
        "strategy": "round_robin",
        "optional": true,
        "modelPrefixes": ["openrouter-"],
        "comment": "활성화: 1) OPENROUTER_API_KEY 발급 2) 본 풀 enabled=true 3) OPENROUTER_ENABLED=true. openrouter.ai 에서 200+ 모델 접근.",
        "accounts": [
          { "id": "openrouter-primary",   "authType": "api_key", "envKey": "OPENROUTER_API_KEY",   "weight": 10, "enabled": false },
          { "id": "openrouter-secondary", "authType": "api_key", "envKey": "OPENROUTER_API_KEY_2", "weight": 10, "enabled": false }
        ]
      }
    },
    "fanOutExample": {
      "comment": "대량 분산 작업용. strategy=fan_out 시 모든 enabled 계정에 동시 발사. pool.sh fanout 액션 지원.",
      "providerId": "zai",
      "strategy": "fan_out",
      "accounts": [
        { "id": "zai-fan-1", "authType": "oauth_zai", "openclawProfile": "default", "plan": "max", "weight": 10, "enabled": true },
        { "id": "zai-fan-2", "authType": "oauth_zai", "openclawProfile": "team",    "plan": "max", "weight": 10, "enabled": true }
      ]
    }
  },

